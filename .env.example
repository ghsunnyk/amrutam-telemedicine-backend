# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. Never commit `.env`.
# Generate every secret below with: openssl rand -base64 48
# In production these come from AWS Secrets Manager / Vault, injected as env vars
# by the orchestrator — nothing is read from a file on disk.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://amrutam:amrutam@localhost:5432/amrutam?schema=public
# Used only by `prisma migrate dev` to detect drift.
SHADOW_DATABASE_URL=postgresql://amrutam:amrutam@localhost:5432/amrutam_shadow?schema=public
DATABASE_POOL_SIZE=20
DATABASE_STATEMENT_TIMEOUT_MS=10000

# --- JWT -------------------------------------------------------------------
# Access tokens are short-lived and stateless; refresh tokens are opaque, stored
# hashed, single-use and rotated. Rotating JWT_ACCESS_SECRET invalidates all
# access tokens within ACCESS_TTL, which is the point.
JWT_ACCESS_SECRET=CHANGE_ME_dev_only_access_secret_at_least_32_chars
JWT_ACCESS_TTL=900          # 15 minutes, seconds
JWT_REFRESH_TTL=1209600     # 14 days, seconds
JWT_ISSUER=amrutam.health
JWT_AUDIENCE=amrutam-api

# --- Cryptography ----------------------------------------------------------
# KEK wraps the per-version DEKs held in `encryption_keys`. 32 raw bytes, base64.
ENCRYPTION_KEK=CHANGE_ME_base64_32_bytes_key_encryption_key____
ENCRYPTION_KEK_ID=local-dev-kek-v1
# Pepper for blind indexes (HMAC-SHA256 over phone / registration number).
# Rotating this requires re-indexing every blind-indexed column.
BLIND_INDEX_PEPPER=CHANGE_ME_base64_32_bytes_blind_index_pepper__
# Salt used to hash IPs before they touch the audit log.
IP_HASH_SALT=CHANGE_ME_base64_16_bytes_ip_salt

# --- Auth policy -----------------------------------------------------------
ARGON2_MEMORY_COST=19456    # 19 MiB — OWASP minimum for argon2id
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15
MFA_ISSUER=Amrutam
# TOTP steps of leeway on either side of `now` (30s each).
MFA_WINDOW=1

# --- Rate limiting ---------------------------------------------------------
RATE_LIMIT_ENABLED=true
# Global fallback, per authenticated user / per IP for anonymous callers.
RATE_LIMIT_GLOBAL_CAPACITY=300
RATE_LIMIT_GLOBAL_REFILL_PER_SEC=5

# --- Idempotency -----------------------------------------------------------
IDEMPOTENCY_TTL_HOURS=24

# --- Observability ---------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=amrutam-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true
# Bearer token guarding GET /metrics. Leave blank to allow unauthenticated scrape
# (only acceptable when the port is not routable from outside the mesh).
METRICS_AUTH_TOKEN=

# --- HTTP ------------------------------------------------------------------
# Comma-separated. `*` is rejected when NODE_ENV=production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BODY_LIMIT=100kb
# Number of proxies in front of the app. Must be exact: too high lets clients
# spoof X-Forwarded-For and defeat IP rate limiting.
TRUST_PROXY_HOPS=1
SHUTDOWN_TIMEOUT_MS=15000

# --- Jobs ------------------------------------------------------------------
WORKER_ENABLED=true
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
# How far ahead the slot materialiser generates bookable slots.
SLOT_HORIZON_DAYS=60
