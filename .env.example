NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://amrutam:amrutam@localhost:5432/amrutam?schema=public
SHADOW_DATABASE_URL=postgresql://amrutam:amrutam@localhost:5432/amrutam_shadow?schema=public
DATABASE_POOL_SIZE=20
DATABASE_STATEMENT_TIMEOUT_MS=10000

JWT_ACCESS_SECRET=CHANGE_ME_dev_only_access_secret_at_least_32_chars
JWT_ACCESS_TTL=900          # 15 minutes, seconds
JWT_REFRESH_TTL=1209600     # 14 days, seconds
JWT_ISSUER=amrutam.health
JWT_AUDIENCE=amrutam-api

ENCRYPTION_KEK=CHANGE_ME_base64_32_bytes_key_encryption_key____
ENCRYPTION_KEK_ID=local-dev-kek-v1
BLIND_INDEX_PEPPER=CHANGE_ME_base64_32_bytes_blind_index_pepper__
IP_HASH_SALT=CHANGE_ME_base64_16_bytes_ip_salt

ARGON2_MEMORY_COST=19456    # 19 MiB — OWASP minimum for argon2id
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15
MFA_ISSUER=Amrutam
MFA_WINDOW=1

RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_CAPACITY=300
RATE_LIMIT_GLOBAL_REFILL_PER_SEC=5

IDEMPOTENCY_TTL_HOURS=24

OTEL_ENABLED=false
OTEL_SERVICE_NAME=amrutam-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BODY_LIMIT=100kb
TRUST_PROXY_HOPS=1
SHUTDOWN_TIMEOUT_MS=15000

WORKER_ENABLED=true
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
SLOT_HORIZON_DAYS=60
