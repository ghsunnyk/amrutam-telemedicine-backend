// Amrutam Telemedicine — data model
//
// Conventions
//  - snake_case in the database, camelCase in the client (@map / @@map everywhere).
//  - UUIDv7-ish ids generated in the DB (gen_random_uuid) so writes never round-trip for an id.
//  - Sensitive columns are suffixed `Enc` and hold an AES-256-GCM envelope produced by
//    src/core/crypto/encryption.ts. Anything we must look up by is paired with a `*Hash`
//    blind index (HMAC-SHA256 under a separate pepper) so equality search survives encryption.
//  - Every mutable clinical/financial row carries `version` for optimistic concurrency.
//
// See docs/architecture.md §Data Model and docs/security.md §Data Classification.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7: connection URLs live in prisma.config.ts (migrations) and are passed to
// PrismaClient via the `pg` driver adapter at runtime — see src/db/prisma.ts.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  PATIENT
  DOCTOR
  ADMIN

  @@map("role")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

enum DoctorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED

  @@map("doctor_verification_status")
}

enum SlotStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED

  @@map("slot_status")
}

enum ConsultationStatus {
  PENDING_PAYMENT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  EXPIRED

  @@map("consultation_status")
}

enum ConsultationMode {
  VIDEO
  AUDIO
  CHAT
  IN_PERSON

  @@map("consultation_mode")
}

enum CancelledBy {
  PATIENT
  DOCTOR
  SYSTEM
  ADMIN

  @@map("cancelled_by")
}

enum PrescriptionStatus {
  DRAFT
  ISSUED
  REVOKED

  @@map("prescription_status")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUND_PENDING
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_status")
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  MOCK

  @@map("payment_provider")
}

enum EncryptionKeyStatus {
  ACTIVE // used for new encryptions
  RETIRED // decrypt-only, pending re-encryption
  COMPROMISED // decrypt-only, re-encrypt immediately

  @@map("encryption_key_status")
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED

  @@map("idempotency_status")
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD

  @@map("job_status")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED

  @@map("outbox_status")
}

enum SagaStatus {
  RUNNING
  COMPLETED
  COMPENSATING
  COMPENSATED
  FAILED

  @@map("saga_status")
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

model User {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email String @unique @db.Citext

  // Argon2id. Null only for future SSO-only accounts.
  passwordHash String? @map("password_hash")

  role   Role
  status UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)

  // MFA (TOTP). Secret is envelope-encrypted; never leaves the service layer.
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  mfaSecretEnc    Bytes?    @map("mfa_secret_enc")
  mfaEnrolledAt   DateTime? @map("mfa_enrolled_at") @db.Timestamptz(3)
  mfaLastUsedStep BigInt?   @map("mfa_last_used_step") // TOTP replay guard

  // Credential-stuffing / brute-force controls.
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(3)

  // Invalidate every access token issued before this instant (logout-all, role change,
  // password reset). Checked on each request against the JWT `iat`.
  tokensValidFrom DateTime @default(now()) @map("tokens_valid_from") @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  profile            Profile?
  doctor             Doctor?
  refreshTokens      RefreshToken[]
  mfaRecoveryCodes   MfaRecoveryCode[]
  patientConsults    Consultation[]        @relation("PatientConsultations")
  payments           Payment[]
  auditLogs          AuditLog[]
  verificationTokens VerificationToken[]

  @@index([status, role])
  @@index([createdAt])
  @@map("users")
}

model Profile {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  firstName String @map("first_name")
  lastName  String @map("last_name")

  // Blind index enables "find by phone" without decrypting the table.
  phoneHash String? @unique @map("phone_hash")
  phoneEnc  Bytes?  @map("phone_enc")

  dateOfBirthEnc Bytes?  @map("date_of_birth_enc")
  genderEnc      Bytes?  @map("gender_enc")
  addressEnc     Bytes?  @map("address_enc")
  avatarUrl      String? @map("avatar_url")

  timezone String @default("Asia/Kolkata")
  locale   String @default("en-IN")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// Refresh tokens are opaque, single-use and rotated. `familyId` groups a login
/// session's rotation chain: presenting an already-rotated token means the token
/// leaked, so we revoke the entire family. Only the SHA-256 of the token is stored.
model RefreshToken {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  familyId  String @map("family_id") @db.Uuid
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  /// Set when this token is exchanged; presence means "already used".
  rotatedAt DateTime? @map("rotated_at") @db.Timestamptz(3)
  /// Why it died — useful in incident review.
  revokedReason String? @map("revoked_reason")

  userAgent String? @map("user_agent")
  ipHash    String? @map("ip_hash")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model MfaRecoveryCode {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  /// Argon2id hash of a single-use recovery code.
  codeHash String    @map("code_hash")
  usedAt   DateTime? @map("used_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("mfa_recovery_codes")
}

/// Single-use, short-lived tokens for email verification and password reset.
/// Only the hash is persisted.
model VerificationToken {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  purpose   String // EMAIL_VERIFY | PASSWORD_RESET
  tokenHash String @unique @map("token_hash")

  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Doctors, specializations, availability
// ---------------------------------------------------------------------------

model Doctor {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  /// Medical council registration. Encrypted + blind-indexed for uniqueness checks.
  registrationNumberHash String @unique @map("registration_number_hash")
  registrationNumberEnc  Bytes  @map("registration_number_enc")
  registrationCouncil    String @map("registration_council")

  verificationStatus DoctorVerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?                @map("verified_at") @db.Timestamptz(3)
  verifiedByUserId   String?                  @map("verified_by_user_id") @db.Uuid
  rejectionReason    String?                  @map("rejection_reason")

  headline           String?
  bio                String?
  yearsOfExperience  Int      @default(0) @map("years_of_experience")
  languages          String[] @default([])
  qualifications     String[] @default([])
  city               String?
  state              String?
  country            String   @default("IN")

  /// Money is integer minor units (paise). Never float.
  consultationFeeMinor Int    @map("consultation_fee_minor")
  currency             String @default("INR") @db.Char(3)

  /// Denormalised rating aggregates, refreshed by a job. Reads never aggregate on the fly.
  ratingAvg   Decimal @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount Int     @default(0) @map("rating_count")

  /// Minutes a patient may hold a slot before checkout expires.
  slotHoldMinutes Int @default(10) @map("slot_hold_minutes")
  /// Default length of a generated slot.
  slotDurationMinutes Int @default(30) @map("slot_duration_minutes")

  isAcceptingPatients Boolean @default(true) @map("is_accepting_patients")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  version   Int      @default(0)

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  specializations DoctorSpecialization[]
  availabilityRules AvailabilityRule[]
  slots           AvailabilitySlot[]
  consultations   Consultation[]
  prescriptions   Prescription[]

  @@index([verificationStatus, isAcceptingPatients])
  @@index([city, consultationFeeMinor])
  @@index([ratingAvg(sort: Desc), ratingCount(sort: Desc)])
  @@map("doctors")
}

model Specialization {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  name        String
  description String?

  doctors DoctorSpecialization[]

  @@map("specializations")
}

model DoctorSpecialization {
  doctorId         String @map("doctor_id") @db.Uuid
  specializationId String @map("specialization_id") @db.Uuid

  doctor         Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialization Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([doctorId, specializationId])
  @@index([specializationId])
  @@map("doctor_specializations")
}

/// Recurring weekly template. Slots are materialised from these rules into
/// `availability_slots` for a rolling horizon by a background job, so the read
/// path (slot search) is a plain indexed range scan.
model AvailabilityRule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorId String @map("doctor_id") @db.Uuid

  /// 0 = Sunday … 6 = Saturday, in `timezone`.
  weekday Int
  /// Minutes from local midnight. 540 = 09:00.
  startMinute Int    @map("start_minute")
  endMinute   Int    @map("end_minute")
  timezone    String @default("Asia/Kolkata")

  slotDurationMinutes Int @default(30) @map("slot_duration_minutes")

  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz(3)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(3)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, weekday, isActive])
  @@map("availability_rules")
}

/// Materialised bookable slot. This is the contention hot spot: booking takes a
/// row lock (`SELECT … FOR UPDATE`) and flips AVAILABLE → HELD → BOOKED.
/// `version` additionally guards optimistic paths.
model AvailabilitySlot {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorId String @map("doctor_id") @db.Uuid

  startAt DateTime @map("start_at") @db.Timestamptz(3)
  endAt   DateTime @map("end_at") @db.Timestamptz(3)

  status SlotStatus @default(AVAILABLE)

  /// Set while status = HELD. The hold expires at `holdExpiresAt`; a sweeper job
  /// (and an opportunistic check on read) releases stale holds.
  heldByUserId  String?   @map("held_by_user_id") @db.Uuid
  holdExpiresAt DateTime? @map("hold_expires_at") @db.Timestamptz(3)
  /// Ties the hold to the checkout attempt that created it.
  holdToken String? @map("hold_token") @db.Uuid

  /// Generated from an AvailabilityRule; null if the doctor added it ad hoc.
  sourceRuleId String? @map("source_rule_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  version   Int      @default(0)

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  consultation Consultation?

  /// A doctor cannot have two slots starting at the same instant.
  @@unique([doctorId, startAt])
  /// The slot-search read path: "available slots for doctor X in window [a,b)".
  @@index([doctorId, status, startAt])
  /// The sweeper path: "holds that expired before now".
  @@index([status, holdExpiresAt])
  /// Cross-doctor search by time window (e.g. "any cardiologist tomorrow 5pm").
  @@index([startAt, status])
  @@map("availability_slots")
}

// ---------------------------------------------------------------------------
// Consultations, prescriptions, payments
// ---------------------------------------------------------------------------

model Consultation {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Human-facing reference, e.g. AMR-2K5F8H3Q. Safe to put in emails/support tickets.
  reference String @unique

  patientId String @map("patient_id") @db.Uuid
  doctorId  String @map("doctor_id") @db.Uuid
  slotId    String @unique @map("slot_id") @db.Uuid

  status ConsultationStatus @default(PENDING_PAYMENT)
  mode   ConsultationMode   @default(VIDEO)

  scheduledStart DateTime @map("scheduled_start") @db.Timestamptz(3)
  scheduledEnd   DateTime @map("scheduled_end") @db.Timestamptz(3)
  startedAt      DateTime? @map("started_at") @db.Timestamptz(3)
  endedAt        DateTime? @map("ended_at") @db.Timestamptz(3)

  /// Price is captured at booking time; the doctor may change their fee later.
  feeMinor Int    @map("fee_minor")
  currency String @default("INR") @db.Char(3)

  /// PHI — encrypted at rest, decrypted only for the treating doctor and the patient.
  chiefComplaintEnc Bytes? @map("chief_complaint_enc")
  symptomsEnc       Bytes? @map("symptoms_enc")
  diagnosisEnc      Bytes? @map("diagnosis_enc")
  doctorNotesEnc    Bytes? @map("doctor_notes_enc")
  followUpNotesEnc  Bytes? @map("follow_up_notes_enc")

  cancelledAt     DateTime?    @map("cancelled_at") @db.Timestamptz(3)
  cancelledBy     CancelledBy? @map("cancelled_by")
  cancelledReason String?      @map("cancelled_reason")

  /// Set when the booking saga expires an unpaid consultation.
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  version   Int      @default(0)

  patient      User             @relation("PatientConsultations", fields: [patientId], references: [id])
  doctor       Doctor           @relation(fields: [doctorId], references: [id])
  slot         AvailabilitySlot @relation(fields: [slotId], references: [id])
  prescription Prescription?
  payments     Payment[]
  review       Review?

  /// "My upcoming consultations", newest first.
  @@index([patientId, status, scheduledStart(sort: Desc)])
  @@index([doctorId, status, scheduledStart(sort: Desc)])
  /// Admin analytics + partition-pruning candidate (see docs/architecture.md).
  @@index([scheduledStart])
  @@index([status, expiresAt])
  @@map("consultations")
}

model Prescription {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultationId String @unique @map("consultation_id") @db.Uuid
  doctorId       String @map("doctor_id") @db.Uuid

  status PrescriptionStatus @default(DRAFT)

  /// Encrypted JSON array of line items:
  /// [{ drug, strength, form, dosage, frequency, durationDays, instructions }]
  itemsEnc   Bytes  @map("items_enc")
  adviceEnc  Bytes? @map("advice_enc")

  /// Detached signature over the canonical prescription payload (Ed25519).
  /// Lets a pharmacy verify authenticity without trusting our API.
  signature      Bytes?  @map("signature")
  signatureKeyId String? @map("signature_key_id")

  issuedAt      DateTime? @map("issued_at") @db.Timestamptz(3)
  validUntil    DateTime? @map("valid_until") @db.Timestamptz(3)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(3)
  revokedReason String?   @map("revoked_reason")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  version   Int      @default(0)

  consultation Consultation @relation(fields: [consultationId], references: [id])
  doctor       Doctor       @relation(fields: [doctorId], references: [id])

  @@index([doctorId, issuedAt(sort: Desc)])
  @@index([status])
  @@map("prescriptions")
}

model Payment {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultationId String @map("consultation_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  provider   PaymentProvider
  status     PaymentStatus   @default(PENDING)

  amountMinor         Int    @map("amount_minor")
  currency            String @default("INR") @db.Char(3)
  refundedAmountMinor Int    @default(0) @map("refunded_amount_minor")

  /// Provider's order/intent id. Unique per provider so webhook replays are no-ops.
  providerOrderId   String? @map("provider_order_id")
  providerPaymentId String? @map("provider_payment_id")
  failureCode       String? @map("failure_code")
  failureMessage    String? @map("failure_message")

  /// The client-supplied Idempotency-Key that created this payment.
  idempotencyKey String? @map("idempotency_key")

  authorizedAt DateTime? @map("authorized_at") @db.Timestamptz(3)
  capturedAt   DateTime? @map("captured_at") @db.Timestamptz(3)
  refundedAt   DateTime? @map("refunded_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  version   Int      @default(0)

  consultation Consultation @relation(fields: [consultationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([provider, providerOrderId])
  @@unique([provider, providerPaymentId])
  @@index([consultationId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("payments")
}

model Review {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultationId String @unique @map("consultation_id") @db.Uuid

  rating  Int
  comment String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Compliance: audit trail
// ---------------------------------------------------------------------------

/// Append-only. Partitioned monthly by `created_at` (see the initial migration);
/// old partitions are detached to cold storage rather than DELETEd.
/// The composite primary key exists because Postgres requires the partition key
/// to be part of every unique constraint.
model AuditLog {
  id        String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  /// Null for anonymous/system actions (failed login on an unknown email, cron jobs).
  actorId   String? @map("actor_id") @db.Uuid
  actorRole Role?   @map("actor_role")

  /// e.g. "consultation.booked", "auth.login.failed", "prescription.issued"
  action       String
  resourceType String  @map("resource_type")
  resourceId   String? @map("resource_id")

  /// Redacted diff. Never contains PHI or credentials — see AuditService.
  metadata Json?

  ipHash    String? @map("ip_hash")
  userAgent String? @map("user_agent")
  requestId String? @map("request_id")
  /// Correlates an audit entry with its distributed trace.
  traceId String? @map("trace_id")

  outcome String @default("SUCCESS") // SUCCESS | FAILURE | DENIED

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@id([id, createdAt])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Platform: encryption keys, idempotency, rate limiting, jobs, outbox, sagas
// ---------------------------------------------------------------------------

/// Envelope encryption. The DEK is stored wrapped by a KEK that lives outside the
/// database (env var in dev, KMS/Vault in prod). Rotating the KEK rewraps rows here;
/// rotating a DEK marks it RETIRED and a background job re-encrypts referencing rows.
model EncryptionKey {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version Int    @unique

  wrappedDek Bytes  @map("wrapped_dek")
  algorithm  String @default("aes-256-gcm")
  /// Which KEK wrapped this DEK, so we can rotate KEKs independently.
  kekId String @map("kek_id")

  status EncryptionKeyStatus @default(ACTIVE)

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  retiredAt  DateTime? @map("retired_at") @db.Timestamptz(3)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(3)

  @@index([status])
  @@map("encryption_keys")
}

/// Makes non-GET writes replay-safe. The first request inserts a row IN_PROGRESS
/// (a unique-violation is what serialises concurrent duplicates); the response is
/// then recorded and replayed verbatim to retries carrying the same key.
model IdempotencyKey {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Namespaced by caller so one user can't hijack another's key.
  scope String
  key   String

  /// SHA-256 of method + path + body. A same-key-different-body retry is a 422,
  /// not a silent replay of the wrong response.
  requestHash String @map("request_hash")

  status IdempotencyStatus @default(IN_PROGRESS)

  responseStatus Int?  @map("response_status")
  responseBody   Json? @map("response_body")

  /// Fencing token: whoever holds it is executing. Lets us detect crashed holders.
  lockedAt DateTime  @default(now()) @map("locked_at") @db.Timestamptz(3)
  lockedBy String?   @map("locked_by")

  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([scope, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

/// Postgres-backed token bucket (no Redis by design — see docs/architecture.md
/// §Why no Redis). Refill is computed in SQL inside a single UPSERT, so the
/// check-and-consume is atomic without an application-side lock.
model RateLimitBucket {
  /// "<policy>:<identity>", e.g. "auth.login:ip:3f2a…"
  id String @id

  tokens         Float
  lastRefillAt   DateTime @map("last_refill_at") @db.Timestamptz(3)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(3)

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

/// Durable job queue. Workers claim rows with `FOR UPDATE SKIP LOCKED`, which gives
/// us competing consumers without a broker. Retries use exponential backoff + jitter.
model Job {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  queue String @default("default")
  type  String

  payload Json

  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")

  /// Next eligible execution time; backoff pushes this forward.
  runAt DateTime @default(now()) @map("run_at") @db.Timestamptz(3)

  lockedAt   DateTime? @map("locked_at") @db.Timestamptz(3)
  lockedBy   String?   @map("locked_by")
  /// Lease expiry — a worker that dies mid-job has its row reclaimed after this.
  leaseUntil DateTime? @map("lease_until") @db.Timestamptz(3)

  lastError   String?   @map("last_error")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)

  /// Collapses duplicate enqueues (e.g. "send reminder for consultation X").
  dedupeKey String? @unique @map("dedupe_key")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  /// The claim query: pending jobs whose time has come, oldest first.
  @@index([queue, status, runAt])
  @@index([status, leaseUntil])
  @@map("jobs")
}

/// Transactional outbox. Domain events are written in the *same* transaction as the
/// state change, then relayed asynchronously — so we never lose an event to a crash
/// between "commit" and "publish".
model OutboxEvent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  aggregateType String @map("aggregate_type")
  aggregateId   String @map("aggregate_id")
  eventType     String @map("event_type")

  payload Json

  status   OutboxStatus @default(PENDING)
  attempts Int          @default(0)

  availableAt DateTime  @default(now()) @map("available_at") @db.Timestamptz(3)
  publishedAt DateTime? @map("published_at") @db.Timestamptz(3)
  lastError   String?   @map("last_error")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

/// Orchestration state for the booking saga (hold → charge → confirm), so a crashed
/// coordinator can resume and, on failure, run compensations in reverse order.
model SagaInstance {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type String

  /// The business entity this saga drives (e.g. a consultation id).
  correlationId String @map("correlation_id")

  status      SagaStatus @default(RUNNING)
  currentStep String     @map("current_step")
  /// Steps completed so far, in order — the compensation stack.
  completedSteps String[] @default([]) @map("completed_steps")

  context Json
  lastError String? @map("last_error")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)

  @@unique([type, correlationId])
  @@index([status, updatedAt])
  @@map("saga_instances")
}
